       <property name="styleSheet">
        <string notr="true">/* 1. Main ComboBox Container */
QComboBox {
    border: 2px solid #008BF8;
    border-radius: 6px;
    padding: 4px 10px;
    min-width: 6em;
    background-color:  qlineargradient(
    		spread:pad,
    		x1:0.5, y1:0,
    		x2:0.5, y2:1,
    		stop:0 #3792d8,
    		stop:1 #2276b5
    );
    color: #ffffff;
    font-size: 14px;
}

/* Main container state variations */
QComboBox:editable {
    background: #008BF8;
}

QComboBox:focus {
    border: 2px solid #295ed5;
}

QComboBox:on {
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    background-color: qlineargradient(
        spread:pad,
        x1:0.5, y1:0,
        x2:0.5, y2:1,
        stop:0 #5f86e0,
        stop:1 #295ed5
    );
}

/* 2. The Drop-Down Arrow Button Wrapper */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px;
    border-left-width: 1px;
    border-left-color: white;
    border-left-style: solid;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

/* The actual arrow icon inside the wrapper */
QComboBox::down-arrow {
    image: url(config/icons/arrow_down.png);
    width: 12px;
    height: 12px;
}

/* Shift arrow slightly down when active */
QComboBox::down-arrow:on {
    top: 1px;
    left: 1px;
}

/* 3. The Popup Menu List View */
QComboBox QAbstractItemView {
    border: 2px solid #295ed5;
    border-top: none;
    background-color: #008BF8;
    color: #ffffff;
    selection-background-color: #295ed5;
    selection-color: #ffffff;
    outline: 0px;
}

/* Individual list items */
QComboBox QAbstractItemView::item {
    min-height: 30px;
    padding-left: 10px;
}

/* Highlighted/Hovered list item */
QComboBox</string>
