     <string notr="true">QPushButton {
    color: #ce9801;
	font-weight: bold;
	text-align: center;
    border: 1px solid #e5a901;
    border-radius: 20px;
    border-style: outset;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #f8e931, stop:1 #fec421);
    }

QPushButton:hover {
    background: qradialgradient(
        cx: 0.3, cy: -0.4, fx: 0.3, fy: -0.4,
        radius: 1.35, stop: 0 #f9ed5a, stop: 1 #fed04d
        );
    }

QPushButton:pressed {
    border-style: inset;
    background: qradialgradient(
        cx: 0.4, cy: -0.1, fx: 0.4, fy: -0.1,
        radius: 1.35, stop: 0 #e6d508, stop: 1 #e5a901
        );
    }
