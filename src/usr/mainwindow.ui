       <property name="styleSheet">
        <string notr="true">QCheckBox{
	color: #2153bf
}

QCheckBox::indicator {
    width: 25px;
    height: 25px;
	border: 2px solid;
	border-radius: 5px;
	border-color: #2c64dc;
}

QCheckBox::indicator:checked {
    background-color: qlineargradient(spread:pad, x1:1, y1:1, x2:0, y2:0, stop:0 #2c64dc, stop:0.878307 #2356c4);
    image: url(config/icons/check-mark.png);
    background-position: center;
}

QCheckBox::indicator::hover {
	background-color: #e1e8fa;
}

QCheckBox::indicator::checked::hover
{
    background-color: qlineargradient(spread:pad, x1:1, y1:1, x2:0, y2:0, stop:0 #5683e3, stop:0.878307 #4273dd);

}</string>
